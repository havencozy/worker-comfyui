    "duration": 5,
    "aspect_ratio": "16:9",
    "seed": 12345,
    "generate_audio": false,
    "options": {
      "fps": 24,
      "steps": 30,
      "guidance_scale": 7.5,
      "motion_strength": 0.5,
      "strength": 0.6
    }
  }
}
